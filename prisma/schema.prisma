generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- NEXT AUTH MODELS ---
//TODO Clomplete the data

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // Hashed password
  role          Role      @default(STUDENT)
  
  // Link to the academic profile
  studentProfile Student? 
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// --- ACADEMIC MODELS ---

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  ON_LEAVE
}

model Student {
  id              String        @id @default(cuid())
  userId          String        @unique // Auth link
  user            User          @relation(fields: [userId], references: [id])
  
  // Personal Data
  governmentId    String        @unique // National ID / Passport
  firstName       String
  lastName        String
  birthDate       DateTime
  personalEmail   String?       // Optional: Secondary email
  phoneNumber1    String
  phoneNumber2    String?       // Optional
  address         String?       // Optional
  
  // Academic Records (Accumulated)
  enrollmentDate  DateTime      @default(now())
  status          StudentStatus @default(ACTIVE)
  averageGrade    Float         @default(0.0) // GPA (Grade Point Average)
  totalCredits    Int           @default(0)   // Total credit units earned
  
  // Relationships
  enrollments     Enrollment[]
}

model Course {
  id              String    @id @default(cuid())
  code            String    @unique // e.g., "PHYS-101"
  name            String
  credits         Int
  isActive        Boolean   @default(true)

  // Prerequisites (Self-relation)
  // Courses that MUST be passed before taking this one
  prerequisites   Course[]  @relation("CoursePrerequisites")
  // Courses that require this course to be passed first
  requiredBy      Course[]  @relation("CoursePrerequisites")

  sections        Section[]
}

model Section {
  id            String   @id @default(cuid())
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id])
  
  professorName String
  room          String
  schedule      String   // e.g., "Mon-Wed 08:00-10:00"
  capacity      Int
  
  enrollments   Enrollment[]
}

model Enrollment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id])
  
  term        String   // e.g., "2026-Q1"
  finalGrade  Float?   // Optional until the term ends
}